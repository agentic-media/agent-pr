{
  "id": "pr",
  "name": "PR",
  "identity": {
    "name": "PR"
  },
  "subagents": {
    "allowAgents": []
  },
  "tools": {
    "alsoAllow": [
      "web_fetch",
      "browser",
      "exec",
      "image_generate",
      "agents_list",
      "message"
    ]
  },
  "sandbox": {
    "docker": {
      "env": {
        "LORDSHIP_AGENT_ROLE": "pr",
        "LORDSHIP_CREDS_DIR": "/role-creds"
      },
      "binds": [
        "/lordship/.role-creds/pr:/role-creds:ro",
        "/lordship/domains:/lordship/domains:ro"
      ]
    }
  }
}
